# ═══════════════════════════════════════════
# Entorno
# ═══════════════════════════════════════════
PROJECT_NAME=Pfinal
ENVIRONMENT=development
DEBUG=true

# ═══════════════════════════════════════════
# Base de datos
# ═══════════════════════════════════════════
DATABASE_URL=sqlite:///local.db

# ═══════════════════════════════════════════
# APIs externas
# ═══════════════════════════════════════════
BLOOMBERG_API_KEY=your_api_key_here
MAX_RETRIES=3
API_TIMEOUT=30.0

# ═══════════════════════════════════════════
# Modelo de ML
# ═══════════════════════════════════════════
MODEL_PATH=models/latest.pkl
RANDOM_SEED=42
BATCH_SIZE=32

MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=financial-sentiment-classification

# ═══════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
