# ═══════════════════════════════════════════
# Entorno virtual
# ═══════════════════════════════════════════
.venv/
venv/
env/

# ═══════════════════════════════════════════
# Python
# ═══════════════════════════════════════════
__pycache__/
*.pyc
*.pyo
*.pyd

# ═══════════════════════════════════════════
# Variables de entorno (CRÍTICO)
# ═══════════════════════════════════════════
.env
.env.*

# Permitir template
!.env.example

# ═══════════════════════════════════════════
# Datos (tu carpeta data/)
# ═══════════════════════════════════════════
data/

# Si quieres mantener estructura:
# data/*
# !data/.gitkeep

# ═══════════════════════════════════════════
# Modelos entrenados (tu carpeta models/)
# ═══════════════════════════════════════════
models/
*.pkl
*.joblib
*.pt
*.h5

# ═══════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════
*.log
logs/

# ═══════════════════════════════════════════
# Notebooks (solo basura interna)
# ═══════════════════════════════════════════
.ipynb_checkpoints/

# ═══════════════════════════════════════════
# IDE / editor
# ═══════════════════════════════════════════
.vscode/
.idea/

# ═══════════════════════════════════════════
# Sistema operativo
# ═══════════════════════════════════════════
.DS_Store
Thumbs.db

# ═══════════════════════════════════════════
# Build / packaging
# ═══════════════════════════════════════════
build/
dist/
*.egg-info/

# ═══════════════════════════════════════════
# Testing
# ═══════════════════════════════════════════
.coverage
htmlcov/
.pytest_cache/

# ═══════════════════════════════════════════
# Configs (opcional dependiendo uso)
# ═══════════════════════════════════════════
# Si en configs tienes YAML/JSON con secretos:
# configs/secrets.yaml

# ═══════════════════════════════════════════
# Scripts temporales
# ═══════════════════════════════════════════
scripts/tmp/
